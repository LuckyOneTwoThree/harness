{
  "_meta": {
    "description": "设计变量示例。UI 设计师使用 Figma 插件导出此格式。",
    "version": "1.0",
    "last_updated": "YYYY-MM-DD",
    "figma_file": "[Figma 链接]"
  },
  "color": {
    "primary": { "50": "#EFF6FF", "500": "#3B82F6", "900": "#1E3A8A" },
    "neutral": { "0": "#FFFFFF", "500": "#6B7280", "900": "#111827" },
    "success": "#10B981",
    "warning": "#F59E0B",
    "error": "#EF4444",
    "info": "#3B82F6"
  },
  "semanticColor": {
    "bg": { "default": "#FFFFFF", "muted": "#F3F4F6" },
    "text": { "primary": "#111827", "secondary": "#4B5563" },
    "border": { "default": "#E5E7EB", "focus": "#3B82F6" }
  },
  "typography": {
    "fontFamily": { "sans": "system-ui, sans-serif" },
    "fontSize": { "sm": "0.875rem", "base": "1rem", "lg": "1.125rem" },
    "fontWeight": { "normal": "400", "medium": "500", "bold": "700" }
  },
  "spacing": {
    "1": "0.25rem", "2": "0.5rem", "4": "1rem", "8": "2rem"
  },
  "borderRadius": {
    "sm": "0.125rem", "default": "0.25rem", "md": "0.375rem", "full": "9999px"
  },
  "shadow": {
    "sm": "0 1px 2px 0 rgba(0,0,0,0.05)", "default": "0 1px 3px 0 rgba(0,0,0,0.1)"
  },
  "zIndex": {
    "base": "0", "dropdown": "100", "sticky": "200", "overlay": "400", "modal": "500", "toast": "700"
  },
  "opacity": {
    "disabled": "0.5", "hover": "0.08"
  },
  "animation": {
    "duration": { "fast": "150ms", "normal": "300ms", "slow": "500ms" },
    "easing": { "ease-in-out": "cubic-bezier(0.4, 0, 0.2, 1)", "bounce": "cubic-bezier(0.68, -0.55, 0.26, 1.55)" }
  },
  "form": {
    "inputHeight": { "sm": "32px", "default": "40px", "lg": "48px" },
    "buttonHeight": { "sm": "32px", "default": "40px", "lg": "48px" }
  },
  "icon": {
    "size": { "sm": "16px", "default": "20px", "lg": "24px", "xl": "32px" }
  },
  "breakpoint": {
    "sm": "640px", "md": "768px", "lg": "1024px", "xl": "1280px"
  }
}
