# ============================================================
# .env.example — 环境上下文模板
# ============================================================
#
# 此文件是 Agent 感知"物理环境"的权威来源。
# Agent 在启动任务前必须读取此文件，了解服务拓扑。
#
# 规则：
#   - 此文件只包含变量名和示例值，不含真实密钥
#   - 真实值通过 CI/CD Secrets 或运维注入
#   - Agent 修改代码时，必须确认涉及的环境变量在此文件中有定义
#   - 如需新增环境变量，必须同时更新此文件
# ============================================================

# ---------- 基础设施 ----------
APP_ENV=development                    # development | staging | production
APP_PORT=8000                          # 服务端口
APP_HOST=0.0.0.0                       # 绑定地址

# ---------- 数据库 ----------
DB_TYPE=postgresql                     # postgresql | mysql | sqlite | mongodb
DB_HOST=localhost
DB_PORT=5432
DB_NAME=myapp_dev
DB_USER=dev_user
DB_PASSWORD=                           # ⚠️ 真实密码通过环境注入，不写在这里
DB_SSL_MODE=disable                    # disable | require | verify-full

# ---------- 缓存 ----------
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600                         # 缓存过期时间（秒）

# ---------- 消息队列（可选）----------
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/
# KAFKA_BROKERS=localhost:9092

# ---------- 外部服务 ----------
# EXTERNAL_API_URL=https://api.example.com
# EXTERNAL_API_KEY=                    # ⚠️ 通过 Secrets 注入

# ---------- 飞书集成 ----------
FEISHU_WEBHOOK_URL=                    # 飞书自定义机器人 Webhook
FEISHU_APP_ID=                         # 飞书应用 ID（如需 API 调用）
FEISHU_APP_SECRET=                     # ⚠️ 通过 Secrets 注入

# ---------- 存储 ----------
# S3_BUCKET=myapp-dev
# S3_REGION=cn-north-1
# S3_ACCESS_KEY=                       # ⚠️ 通过 Secrets 注入
# S3_SECRET_KEY=                       # ⚠️ 通过 Secrets 注入

# ---------- 日志 ----------
LOG_LEVEL=debug                        # debug | info | warn | error
LOG_FORMAT=json                        # json | text

# ---------- Agent 运行环境 ----------
# 以下变量帮助 Agent 感知当前执行环境
# OS_FAMILY=linux                      # linux | darwin | windows
# SHELL_TYPE=bash                      # bash | zsh | powershell
# CONTAINER=false                      # 是否运行在容器中
# CI=false                             # 是否在 CI 环境中
