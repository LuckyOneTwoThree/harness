# 环境变量（永远不提交）
.env
.env.local
.env.*.local
.env.production
.envrc

# 密钥与凭据
*.key
*.pem
*.p12
*.jks
*.keystore
credentials.json
secret.json
**/secrets/

# 依赖目录
node_modules/
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
vendor/

# 构建产物
dist/
build/
*.egg-info/
target/
*.class
*.jar
*.war

# Go 编译产物
*.exe
*.exe~
*.dll
*.so
*.dylib

# Terraform 状态（含敏感基础设施信息）
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars

# IDE 配置
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

